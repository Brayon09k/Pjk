-- ESP com nome e distância (função original)
local function updateESP()
    for _, bill in ipairs(espBillboards) do
        if bill then bill:Destroy() end
    end
    espBillboards = {}
    for _, conn in ipairs(espConnections) do
        conn:Disconnect()
    end
    espConnections = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local function addBillboard(char)
                if char and char:FindFirstChild("Head") then
                    local head = char.Head
                    local bill = Instance.new("BillboardGui")
                    bill.Size = UDim2.new(0, 200, 0, 50)
                    bill.StudsOffset = Vector3.new(0, 3, 0)
                    bill.AlwaysOnTop = true
                    bill.Parent = head

                    local nome = Instance.new("TextLabel")
                    nome.Size = UDim2.new(1, 0, 0.5, 0)
                    nome.BackgroundTransparency = 1
                    nome.Text = player.Name
                    nome.TextColor3 = espColor
                    nome.TextStrokeColor3 = Color3.new(0, 0, 0)
                    nome.TextStrokeTransparency = 0.3
                    nome.Font = Enum.Font.GothamBold
                    nome.TextSize = 16
                    nome.Parent = bill

                    local distLabel = Instance.new("TextLabel")
                    distLabel.Size = UDim2.new(1, 0, 0.5, 0)
                    distLabel.Position = UDim2.new(0, 0, 0.5, 0)
                    distLabel.BackgroundTransparency = 1
                    distLabel.Text = ""
                    distLabel.TextColor3 = Color3.new(1, 1, 1)
                    distLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
                    distLabel.TextStrokeTransparency = 0.3
                    distLabel.Font = Enum.Font.Gotham
                    distLabel.TextSize = 14
                    distLabel.Parent = bill

                    table.insert(espBillboards, bill)

                    local conn = RunService.Heartbeat:Connect(function()
                        if char and char:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            local dist = (char.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                            distLabel.Text = string.format("%.1f m", dist)
                        else
                            distLabel.Text = "?"
                        end
                    end)
                    table.insert(espConnections, conn)
                end
            end
            addBillboard(player.Character)
            local conn = player.CharacterAdded:Connect(function(char)
                task.wait(0.5)
                addBillboard(char)
            end)
            table.insert(espConnections, conn)
        end
    end
end

local function clearESP()
    for _, bill in ipairs(espBillboards) do
        if bill then bill:Destroy() end
    end
    espBillboards = {}
    for _, conn in ipairs(espConnections) do
        conn:Disconnect()
    end
    espConnections = {}
end

