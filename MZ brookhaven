local function criarAba(nome)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 100, 0, 30)
    btn.Position = UDim2.new(0, (#tabs * 100), 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.BackgroundTransparency = 0 -- opaco
    btn.Text = nome
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = main
    table.insert(tabs, btn)

    local container = Instance.new("ScrollingFrame")
    container.Size = UDim2.new(1, 0, 1, -60)
    container.Position = UDim2.new(0, 0, 0, 60)
    container.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    container.BackgroundTransparency = 0.2 -- um pouco transparente para ver o fundo
    container.ScrollBarThickness = 6
    container.Visible = false
    container.Parent = main
    table.insert(containers, container)

    -- Layout automático
    local layout = Instance.new("UIListLayout")
    layout.Parent = container
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 2)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        container.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)

    -- Padding para centralizar o conteúdo
    local padding = Instance.new("UIPadding")
    padding.Parent = container
    padding.PaddingLeft = UDim.new(0, 5)
    padding.PaddingRight = UDim.new(0, 5)

    btn.MouseButton1Click:Connect(function()
        for i, c in ipairs(containers) do
            c.Visible = false
            tabs[i].BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end
        container.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(70, 70, 140)
    end)

    return container
end

