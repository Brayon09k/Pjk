    addSection(tabInicio, "Status")
    local fpsLabel = addParagraph(tabInicio, "FPS", "0")
    local playerCount = addParagraph(tabInicio, "Jogadores", "0")

    -- Cálculo de FPS
    local lastTime = os.clock()
    local frames = 0
    coroutine.wrap(function()
        while true do
            RunService.RenderStepped:Wait()
            frames = frames + 1
            local now = os.clock()
            if now - lastTime >= 1 then
                fpsLabel:Set(frames)
                frames = 0
                lastTime = now
            end
            playerCount:Set(#Players:GetPlayers())
        end
    end)()

