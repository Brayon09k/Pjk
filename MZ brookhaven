local function addDropdown(parent, opcoes, descricao, padrao, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 25)
    frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    frame.BackgroundTransparency = 0 -- opaco
    frame.Parent = parent
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = padrao or "Selecione"
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextStrokeColor3 = Color3.new(0, 0, 0)
    btn.TextStrokeTransparency = 0.3
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = frame

    local list = Instance.new("ScrollingFrame")
    list.Size = UDim2.new(1, 0, 0, 100)
    list.Position = UDim2.new(0, 0, 1, 0)
    list.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    list.BackgroundTransparency = 0 -- opaco
    list.Visible = false
    list.Parent = frame
    list.ScrollBarThickness = 4
    list.ZIndex = 10

    local listLayout = Instance.new("UIListLayout")
    listLayout.Parent = list
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 1)

    local function populate(opts)
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, opt in ipairs(opts) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 22)
            optBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            optBtn.BackgroundTransparency = 0 -- opaco
            optBtn.Text = opt
            optBtn.TextColor3 = Color3.new(1, 1, 1)
            optBtn.TextStrokeColor3 = Color3.new(0, 0, 0)
            optBtn.TextStrokeTransparency = 0.3
            optBtn.Font = Enum.Font.Gotham
            optBtn.TextSize = 12
            optBtn.Parent = list
            optBtn.ZIndex = 11
            optBtn.MouseButton1Click:Connect(function()
                btn.Text = opt
                list.Visible = false
                if callback then callback(opt) end
            end)
        end
        list.CanvasSize = UDim2.new(0, 0, 0, #opts * 23)
    end

    btn.MouseButton1Click:Connect(function()
        populate(opcoes)
        list.Visible = not list.Visible
    end)

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            task.wait()
            if list.Visible then
                local mousePos = UserInputService:GetMouseLocation()
                local absPos = frame.AbsolutePosition
                local size = frame.AbsoluteSize
                if mousePos.X < absPos.X or mousePos.X > absPos.X + size.X or
                   mousePos.Y < absPos.Y or mousePos.Y > absPos.Y + size.Y + 100 then
                    list.Visible = false
                end
            end
        end
    end)

    if descricao then
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, -20, 0, 16)
        desc.Position = UDim2.new(0, 10, 0, 25)
        desc.BackgroundTransparency = 1
        desc.Text = descricao
        desc.TextColor3 = Color3.fromRGB(180, 180, 180)
        desc.TextStrokeColor3 = Color3.new(0, 0, 0)
        desc.TextStrokeTransparency = 0.5
        desc.Font = Enum.Font.Gotham
        desc.TextSize = 11
        desc.TextXAlignment = Enum.TextXAlignment.Left
        desc.Parent = parent
    end

    return {
        Set = function(novasOpcoes) populate(novasOpcoes) end
    }
end

