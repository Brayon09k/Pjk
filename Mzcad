local function toggleBlackHole(v)
    blackHoleActive = v
    if blackHoleActive then
        local sky = Instance.new("Sky")
        sky.SkyboxBk="rbxassetid://8139676647"
        sky.SkyboxDn="rbxassetid://8139676988"
