-- Função para criar aba
local function createTab(name)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 100, 0, 30)
    btn.Position = UDim2.new(0, (#tabs * 100), 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.Text = name
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = main
    table.insert(tabs, btn)

    local frame = Instance.new("ScrollingFrame")
    frame.Size = UDim2.new(1, 0, 1, -60)
    frame.Position = UDim2.new(0, 0, 0, 60)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BackgroundTransparency = 0.1
    frame.ScrollBarThickness = 6
    frame.Visible = false
    frame.Parent = main
    table.insert(tabFrames, frame)

    -- Layout automático
    local layout = Instance.new("UIListLayout")
    layout.Parent = frame
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 5)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        frame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)

    btn.MouseButton1Click:Connect(function()
        for i, f in ipairs(tabFrames) do
            f.Visible = false
            tabs[i].BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end
        frame.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(70, 70, 140)
    end)

    return frame
end

