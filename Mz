-- Métodos Matar/Puxar
addSection(tabTroll, "Ações")
local metodos = {"Matar", "Puxar"}
local metodoSelecionado = "Matar"
local metodoDropdown = addDropdown(tabTroll, metodos, "Matar", function(opt) metodoSelecionado = opt end)

local function funcaoMatar()
    while acaoAtiva and selectedTarget and selectedTarget.Character do
        local targetRoot = selectedTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then targetRoot.CFrame = CFrame.new(0, -500, 0) end
        task.wait(0.1)
    end
end

local function funcaoPuxar()
    local clearRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Clea1rTool1s")
    if clearRemote then clearRemote:FireServer("ClearAllTools") end
    task.wait(0.2)
    local toolRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Too1l")
    if toolRemote then toolRemote:InvokeServer("PickingTools", "Couch") end
    task.wait(0.3)
    local couch = LocalPlayer.Backpack:FindFirstChild("Couch")
    if not couch then warn("Sofá não encontrado"); return end
    couch.Parent = LocalPlayer.Character
    task.wait(0.1)
    local seat1 = couch:FindFirstChild("Seat1")
    local seat2 = couch:FindFirstChild("Seat2")
    if seat1 and seat2 then seat1.Disabled = true; seat2.Disabled = true end
    while acaoAtiva and selectedTarget and selectedTarget.Character and couch.Parent do
        local targetRoot = selectedTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot and seat1 then
            seat1.CFrame = targetRoot.CFrame * CFrame.new(0, 2, -2)
        else break end
        task.wait()
    end
    if couch and couch.Parent then couch.Parent = LocalPlayer.Backpack end
    if clearRemote then clearRemote:FireServer("ClearAllTools") end
end

addButton(tabTroll, "Executar", function()
    if not selectedTarget then warn("Selecione um jogador!"); return end
    if acaoAtiva then warn("Ação em andamento. Use 'Parar'."); return end
    acaoAtiva = true
    if metodoSelecionado == "Matar" then
        acaoThread = task.spawn(funcaoMatar)
    else
        acaoThread = task.spawn(funcaoPuxar)
    end
end)

addButton(tabTroll, "Parar", function()
    acaoAtiva = false
    if acaoThread then task.cancel(acaoThread); acaoThread = nil end
    local clearRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Clea1rTool1s")
    if clearRemote then clearRemote:FireServer("ClearAllTools") end
end)

