-- Função para criar aba
local function criarAba(nome)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.Position = UDim2.new(0, 5, 0, #abas * 40 + 5)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.BackgroundTransparency = 0.2
    btn.Text = nome
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = sidebar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local container = Instance.new("ScrollingFrame")
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0
    container.ScrollBarThickness = 4
    container.Visible = false
    container.Parent = contentArea

    -- Layout automático
    local layout = Instance.new("UIListLayout")
    layout.Parent = container
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 5)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    container.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end)

btn.MouseButton1Click:Connect(function()
    for i, c in ipairs(containers) do
        c.Visible = false
        abas[i].BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end
    container.Visible = true
    btn.BackgroundColor3 = Color3.fromRGB(70, 70, 140)   -- só o botão clicado fica destacado
end)

    table.insert(abas, btn)
    table.insert(containers, container)

    -- Métodos para adicionar elementos
    local methods = {}
    function methods:AddSection(texto)
        local sec = Instance.new("TextLabel")
        sec.Size = UDim2.new(1, -10, 0, 25)
        sec.BackgroundTransparency = 1
        sec.Text = texto
        sec.TextColor3 = Color3.fromRGB(200, 200, 200)
        sec.Font = Enum.Font.GothamBold
        sec.TextSize = 16
        sec.TextXAlignment = Enum.TextXAlignment.Left
        sec.Parent = container
    end

    function methods:AddButton(texto, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 30)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        btn.BackgroundTransparency = 0.1
        btn.Text = texto
        btn.TextColor3 = Color3.new(1, 1, 1)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 14
        btn.Parent = container
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        btn.MouseButton1Click:Connect(callback)
    end

    function methods:AddToggle(texto, padrao, callback)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -10, 0, 30)
        frame.BackgroundTransparency = 1
        frame.Parent = container

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.7, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = texto
        label.TextColor3 = Color3.new(1, 1, 1)
        label.Font = Enum.Font.Gotham
        label.TextSize = 14
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = frame

        local toggle = Instance.new("TextButton")
        toggle.Size = UDim2.new(0, 30, 0, 20)
        toggle.Position = UDim2.new(1, -35, 0.5, -10)
        toggle.BackgroundColor3 = padrao and Color3.new(0, 1, 0) or Color3.new(0.5, 0.5, 0.5)
        toggle.Text = ""
        toggle.Parent = frame
        Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

        local state = padrao
        toggle.MouseButton1Click:Connect(function()
            state = not state
            toggle.BackgroundColor3 = state and Color3.new(0, 1, 0) or Color3.new(0.5, 0.5, 0.5)
            callback(state)
        end)
    end

    function methods:AddTextBox(dados)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -10, 0, 50)
        frame.BackgroundTransparency = 1
        frame.Parent = container

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 20)
        label.BackgroundTransparency = 1
        label.Text = dados.Title or "Input"
        label.TextColor3 = Color3.new(1, 1, 1)
        label.Font = Enum.Font.Gotham
        label.TextSize = 14
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = frame

        local box = Instance.new("TextBox")
        box.Size = UDim2.new(1, 0, 0, 25)
        box.Position = UDim2.new(0, 0, 0, 20)
        box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        box.BackgroundTransparency = 0.1
        box.Text = dados.Default or ""
        box.TextColor3 = Color3.new(1, 1, 1)
        box.PlaceholderText = dados.PlaceholderText or dados.Title
        box.Font = Enum.Font.Gotham
        box.TextSize = 14
        box.Parent = frame
        Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)

        box.FocusLost:Connect(function()
            dados.Callback(box.Text)
        end)

        return {
            Set = function(t) box.Text = t end,
            GetText = function() return box.Text end
        }
    end

    function methods:AddParagraph(titulo, valor)
        local para = Instance.new("TextLabel")
        para.Size = UDim2.new(1, -10, 0, 20)
        para.BackgroundTransparency = 1
        para.Text = titulo .. ": " .. valor
        para.TextColor3 = Color3.new(1, 1, 1)
        para.Font = Enum.Font.Gotham
        para.TextSize = 14
        para.TextXAlignment = Enum.TextXAlignment.Left
        para.Parent = container

        return { Set = function(t) para.Text = titulo .. ": " .. t end }
    end

    return methods
end

