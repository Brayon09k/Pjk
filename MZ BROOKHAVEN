-- Função de MATAR (exemplo com ônibus – adapte se quiser)
local function funcaoMatar()
    while acaoAtiva and selectedTarget and selectedTarget.Character do
        local targetRoot = selectedTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            -- Exemplo: teleporta o alvo para o void (mude para seu método preferido)
            targetRoot.CFrame = CFrame.new(0, -500, 0)
        end
        task.wait(0.1)
    end
end

-- Função de PUXAR (com sofá) – baseada no Drip Client
local function funcaoPuxar()
    -- Limpa ferramentas antigas
    local args = { [1] = "ClearAllTools" }
    local clearRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Clea1rTool1s")
    if clearRemote then clearRemote:FireServer(unpack(args)) end
    task.wait(0.2)

    -- Pega o sofá
    local toolRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Too1l")
    if toolRemote then
        toolRemote:InvokeServer("PickingTools", "Couch")
    end
    task.wait(0.3)

    local couch = LocalPlayer.Backpack:FindFirstChild("Couch")
    if not couch then
        warn("Sofá não encontrado")
        return
    end
    couch.Parent = LocalPlayer.Character
    task.wait(0.1)

    -- Desabilita os assentos do sofá
    local seat1 = couch:FindFirstChild("Seat1")
    local seat2 = couch:FindFirstChild("Seat2")
    if seat1 and seat2 then
        seat1.Disabled = true
        seat2.Disabled = true
    end

    -- Loop de puxar
    while acaoAtiva and selectedTarget and selectedTarget.Character and couch.Parent do
        local targetRoot = selectedTarget.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot and seat1 then
            seat1.CFrame = targetRoot.CFrame * CFrame.new(0, 2, -2)
        else
            break
        end
        task.wait()
    end

    -- Limpeza
    if couch and couch.Parent then
        couch.Parent = LocalPlayer.Backpack
    end
    if clearRemote then
        clearRemote:FireServer("ClearAllTools")
    end
end

