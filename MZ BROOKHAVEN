-- BOTÃO PRINCIPAL: Enviar pirralho
Tabs.Troll:AddButton("Enviar Pirralho", function()
    if not chasingplayer then
        warn("Nenhum jogador selecionado!")
        return
    end

    local targetChar = workspace:FindFirstChild(chasingplayer.Name)
    if not targetChar then
        warn("Jogador alvo não encontrado no workspace.")
        return
    end

    -- Se o pirralho ainda não existe, cria ele
    if not workspace:FindFirstChild(LocalPlayer.Name) or not workspace[LocalPlayer.Name]:FindFirstChild("FollowCharacter") then
        local babyRemote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Bab1yFollo1w")
        if babyRemote then
            babyRemote:FireServer("CharacterFollowSpawnPlayer", "BabyBoy")
            task.wait(0.3)
        else
            warn("Remote da criança não encontrado. O jogo pode ter atualizado.")
            return
        end
    end

    local pirralho = workspace[LocalPlayer.Name] and workspace[LocalPlayer.Name]:FindFirstChild("FollowCharacter")
    local parteAlvo = targetChar:FindFirstChild(parteSelecionada)

    if pirralho and parteAlvo then
        -- Move o pirralho para o personagem do alvo
        pirralho.Parent = targetChar

        -- Desconecta qualquer conexão anterior
        if babyConn then
            babyConn:Disconnect()
            babyConn = nil
        end

        -- Conexão para manter o pirralho na parte escolhida
        babyConn = RunService.Heartbeat:Connect(function()
            if pirralho and pirralho:FindFirstChild("Torso") and parteAlvo and parteAlvo.Parent then
                pirralho.Torso.BodyPosition.Position = parteAlvo.Position
                pirralho.Torso.BodyGyro.CFrame = parteAlvo.CFrame
            else
                if babyConn then
                    babyConn:Disconnect()
                    babyConn = nil
                end
            end
        end)
    else
        warn("A parte '" .. parteSelecionada .. "' não existe no jogador alvo.")
    end
end)

