-- Void Protection
local voidEnabled = false
Protect:AddToggle("Void Protection", false, function(v)
    voidEnabled = v
    if v then
        if not _G.voidConn then
            _G.voidConn = RunService.Heartbeat:Connect(function()
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    if LocalPlayer.Character.HumanoidRootPart.Position.Y < -50 then
                        LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(0, 50, 0)
                    end
                end
            end)
        end
    else
        if _G.voidConn then _G.voidConn:Disconnect() _G.voidConn = nil end
    end
end)

-- Anti Sit
local antiSit = false
Protect:AddToggle("Anti Sit", false, function(v) antiSit = v end)

-- Anti Fling (protege contra fling de outros scripts)
local antiFling = false
Protect:AddToggle("Anti Fling", false, function(v)
    antiFling = v
    if v then
        if not _G.flingConn then
            _G.flingConn = RunService.Heartbeat:Connect(function()
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = LocalPlayer.Character.HumanoidRootPart
                    if hrp.Velocity.Magnitude > 200 then
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.Anchored = true
                        task.wait(0.1)
                        hrp.Anchored = false
                    end
                end
            end)
        end
    else
        if _G.flingConn then _G.flingConn:Disconnect() _G.flingConn = nil end
    end
end)

-- Anti Flashbang / Skybox
local antiFlash = false
Protect:AddToggle("Anti Flashbang", false, function(v)
    antiFlash = v
    if v then
        if not _G.flashConn then
            _G.flashConn = RunService.Stepped:Connect(function()
                local cam = workspace.CurrentCamera
                for _, obj in ipairs(cam:GetChildren()) do
                    if obj:IsA("BasePart") and obj.Name == "water" then
                        obj:Destroy()
                    end
                end
            end)
        end
    else
        if _G.flashConn then _G.flashConn:Disconnect() _G.flashConn = nil end
    end
end)

-- Anti Lag (remove itens desnecessários do personagem)
local antiLag = false
Protect:AddToggle("Anti Lag", false, function(v)
    antiLag = v
    if v then
        if not _G.lagConn then
            _G.lagConn = task.spawn(function()
                while antiLag do
                    task.wait(2)
                    if LocalPlayer.Character then
                        for _, item in ipairs(LocalPlayer.Character:GetChildren()) do
                            if item:IsA("Tool") or item:IsA("Accessory") then
                                -- Remove itens que não são essenciais (ex: celular, bola)
                                if item.Name:match("Phone") or item.Name:match("Ball") or item.Name:match("Taser") then
                                    item:Destroy()
                                end
                            end
                        end
                    end
                end
            end)
        end
    else
        if _G.lagConn then task.cancel(_G.lagConn) _G.lagConn = nil end
    end
end)
